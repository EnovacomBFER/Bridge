       ] ) ;
       fhir:reference [
         fhir:l <https://enovacom.org/fhir/bridge/StructureDefinition/episodeOfCare-enovacom-bridge> ;
         fhir:reference [ fhir:v "StructureDefinition/episodeOfCare-enovacom-bridge" ]
       ] ;
       fhir:name [ fhir:v "Enovacom Bridge EpisodeOfCare Profile" ] ;
       fhir:description [ fhir:v "Ce profil de la ressource Encounter sert à définir le dossier administratif du patient en lien avec ces différentes venues.\nThis profil constrains the Encounter resource to represent the patients administrative file in relation to these different visits." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
