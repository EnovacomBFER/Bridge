       ] ;
       fhir:name [ fhir:v "Enovacom Bridge Encounter Visit Profile" ] ;
       fhir:description [ fhir:v "Ce profil de la ressource Encounter sert à définir la venue dans l'établissement du patient. \n\nL'élément Encounter.location est slicé pour permettre de renseigner l'unité fonctionnelle de responsabilité médicale (UFM) et l'unité fonctionnelle d'hébergement du patient (UFH)" ] ;
